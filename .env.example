# Backend API keys. Copy to .env and fill in your values.
# Used by: backend server, ingest script

# Supabase (vector DB + storage)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Hugging Face (embeddings for RAG)
HUGGINGFACE_API_KEY=

# LLM providers (explain endpoint)
GROQ_API_KEY=
GEMINI_API_KEY=

# CORS: production frontend URL (e.g. Vercel demo site). Set on EC2 only.
FRONTEND_URL=
